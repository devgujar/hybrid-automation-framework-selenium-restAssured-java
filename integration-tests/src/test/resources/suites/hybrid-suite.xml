<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Hybrid suite: orchestrates UI + API in the integration-tests module. -->
<suite name="Hybrid-Suite" parallel="methods" thread-count="2">

    <!-- Listeners auto-registered globally via TestNG ServiceLoader in 'common'. -->

    <test name="Hybrid-Tests">
        <groups>
            <run>
                <include name="hybrid"/>
            </run>
        </groups>
        <classes>
            <class name="hybrid.tests.CustomerHybridTest"/>
        </classes>
    </test>
</suite>

